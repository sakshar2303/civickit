  "scripts": {
    "migrate:dev": "npx prisma migrate dev --name init --schema ./src/prisma/schema.prisma --config ./src/prisma.config.ts",
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "test": "vitest",
    "test:integration": "vitest --config vitest.integration.config.js",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "db:test:setup": "DATABASE_URL=$TEST_DATABASE_URL npx prisma migrate deploy",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:setup": "docker compose up -d && sleep 2 && npx prisma db push && npx prisma generate"
