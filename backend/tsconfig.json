{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "lib": [
      "ES2020"
    ],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": [
      "node",
      "vitest/globals"
    ],
    "ignoreDeprecations": "5.0",
  },
  "include": [
    "src/**/*",
    "tests/**/*"
, "vitest.integration.config.js"  ],
  "exclude": [
    "node_modules"
  ]
}